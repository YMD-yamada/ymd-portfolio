# 任意。コピーして .env として使う、または CI のシークレットに設定（GitHub Actions など）
# ローカルでは: setx NETLIFY_AUTH_TOKEN 値   （要再起動）など

# 公開 API のレート制限に余裕を持たせる場合（60 req/h 以上が必要なとき等）
# GITHUB_TOKEN=ghp_...
# または GH_TOKEN=

# https://app.netlify.com → User settings → Applications → Personal access tokens
# NETLIFY_AUTH_TOKEN=

# Vercel → Account Settings → Tokens
# VERCEL_TOKEN=

# Render → Account Settings → API Keys
# RENDER_API_KEY=

# Cloudflare (Pages read)
# API Token: https://dash.cloudflare.com/profile/api-tokens
# 権限例: Account / Cloudflare Pages / Read
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
