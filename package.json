{
  "name": "ymd-personal-site",
  "version": "1.0.0",
  "private": true,
  "description": "Professional static portfolio with apps.json sync (GitHub, Netlify, Vercel, Render, Cloudflare).",
  "type": "module",
  "scripts": {
    "sync:apps": "node scripts/sync-apps.mjs",
    "dev": "npx -y http-server -p 8080 -c-1 .",
    "build": "node scripts/sync-apps.mjs",
    "deploy:pages": "wrangler pages deploy . --project-name=ymd-portfolio-site --commit-dirty=true"
  },
  "devDependencies": {
    "wrangler": "3.90.0"
  }
}
